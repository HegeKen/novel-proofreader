{
  "default": {
    "identifier": "default",
    "description": "Default capability for the main window",
    "local": true,
    "windows": [
      "main"
    ],
    "permissions": [
      "core:default",
      "fs:default",
      "fs:allow-read",
      "fs:allow-write",
      "fs:allow-exists",
      "dialog:default",
      "dialog:allow-open",
      "dialog:allow-save"
    ]
  }
}